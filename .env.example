# Database
DATABASE_URL=postgres://treemap:treemap@localhost:5432/treemap

# Auth (Auth.js)
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Email (Resend) — used for verification, password reset, invitations
RESEND_API_KEY=
RESEND_FROM=TreeMap <hello@example.com>

# Object storage (Cloudflare R2 — S3 compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=treemap-media
R2_PUBLIC_BASE_URL=

# Map tiles (MapTiler key for vector basemap)
NEXT_PUBLIC_MAPTILER_KEY=
